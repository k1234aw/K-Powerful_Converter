{
  "name": "powerful-converter",
  "version": "0.1.4",
  "description": "Portable Windows file converter for images and PDFs.",
  "author": "Local",
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "smoke": "node tests/conversion-smoke.js",
    "build": "electron-builder --win portable",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac zip"
  },
  "dependencies": {
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "@jsquash/jxl": "^1.3.0",
    "ffmpeg-static": "^5.2.0",
    "jxl-wasm": "^0.7.0",
    "node-poppler": "^7.2.4",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.5",
    "wasm-imagemagick": "^1.2.8"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.local.powerfulconverter",
    "productName": "Powerful Converter",
    "asar": true,
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "icon": "src/renderer/assets/logo.ico",
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/node-poppler/**/*",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/jxl-wasm/**/*",
      "node_modules/@jsquash/**/*",
      "node_modules/@cornerstonejs/**/*"
    ],
    "win": {
      "icon": "src/renderer/assets/logo.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    }
  }
}
